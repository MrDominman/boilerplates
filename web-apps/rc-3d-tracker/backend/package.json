{
  "name": "rc-3d-tracker-backend",
  "version": "1.0.0",
  "description": "Backend API for RC 3D Printing Project Tracker",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "build": "echo 'No build step required for Node.js'",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:init": "node database/init.js",
    "db:reset": "rm -f database.sqlite && npm run db:init"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "sqlite3": "^5.1.6",
    "express-validator": "^7.0.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "api",
    "express",
    "sqlite",
    "3d-printing",
    "project-management"
  ],
  "author": "RC 3D Tracker Team",
  "license": "MIT"
}

